generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id                      String   @id @default(uuid())
  title                   String
  content                 String
  due_date                DateTime
  done                    Boolean  @default(false)
  last_request_timestamp  DateTime @default(now())
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@index([due_date])
  @@index([updated_at])
}